rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ═══════════════════════════════════════════════════════════════════
    // REGLAS PARA DESARROLLO - Permisivas
    // TODO: Restringir en producción para que solo accedan a sus propios datos
    // ═══════════════════════════════════════════════════════════════════

    // Perfiles de usuario - solo el propio usuario puede escribir
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Partidos - cualquier usuario autenticado puede leer/escribir
    match /matches/{matchId} {
      allow read, write: if request.auth != null;

      // Subcolección de análisis
      match /analysis/{analysisId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
