rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas permisivas para desarrollo - permiten acceso a usuarios autenticados
    // En producción, restringir a que solo puedan acceder a sus propios documentos

    // Perfiles de usuario
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Partidos - cualquier usuario autenticado puede leer/escribir
    match /matches/{matchId} {
      allow read, write: if request.auth != null;

      // Subcolección de análisis
      match /analysis/{analysisId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
